# Copy to .env and fill. NEVER commit the real .env.

# --- Django ---
DJANGO_SECRET_KEY=change-me-in-prod
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=edus.ro,www.edus.ro

# --- Database ---
# Leave SURVEY_DB_ENGINE unset (or != postgres) for local SQLite logic tests.
# Set to 'postgres' to use the shared instance.
SURVEY_DB_ENGINE=postgres
POSTGRES_DB=edus
POSTGRES_USER=edus
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Dedicated schema in the shared SEAP instance (ASSUMPTION — confirm with the
# SEAP dev before first migrate; backend spec §11).
SURVEY_DB_SCHEMA=survey

# --- Catalogue ---
# Defaults to ../catalogue/questions.json relative to the Django root.
# SURVEY_CATALOGUE_PATH=/abs/path/to/questions.json

# --- CRM sync (World 3, contact-only) ---
# Unset until the CRM webhook format is confirmed; sync_crm runs dry until then.
# CRM_WEBHOOK_URL=
